<resources>
    <string name="app_name">ADgo</string>
    <string name="subtitle">广告自动跳过助手</string>

    <string name="description">ADgo 使用 Android 无障碍服务，自动检测屏幕上出现的“下一步”“跳过”“Next”“Skip”按钮并点击，帮助你无感跳过应用内广告。\n\n使用步骤：\n1. 点击下方按钮，跳转到系统无障碍设置页面。\n2. 在已下载应用列表中找到“ADgo”并开启。\n3. 开启后返回，服务将在后台全局运行。\n\n注意：服务对所有前台应用生效。使用完毕后，请前往无障碍设置关闭，或直接卸载本应用。</string>

    <string name="btn_enable">开启无障碍服务</string>
    <string name="allowlist_title">安全模式（仅指定应用）</string>
    <string name="allowlist_desc">开启后，自动点击只会在下方填写的包名中生效；多项可用换行、逗号或分号分隔。</string>
    <string name="allowlist_switch">启用包名白名单</string>
    <string name="auto_save_switch">自动保存规则</string>
    <string name="auto_save_desc">开启后，选择应用或修改白名单开关会自动保存，无需再点“保存规则”。</string>
    <string name="btn_select_apps">选择应用列表</string>
    <string name="btn_select_all_apps">全选</string>
    <string name="btn_invert_apps">反选</string>
    <string name="btn_clear_apps">清空</string>
    <string name="select_apps_title">选择需要自动处理的应用</string>
    <string name="search_apps_hint">按应用名或包名搜索</string>
    <string name="no_apps_found">未找到可选择的应用</string>
    <string name="allowlist_hint">示例：
com.ss.android
com.tencent
tv.danmaku.bili</string>
    <string name="btn_save_rules">保存规则</string>
    <string name="save_success">规则已保存</string>

    <string name="accessibility_service_description">ADgo 将监测屏幕内容，自动识别并点击广告跳过按钮（Next / Skip / 下一步 / 跳过）。</string>
