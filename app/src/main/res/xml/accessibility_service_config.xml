<?xml version="1.0" encoding="utf-8"?>
<!--
    No android:packageNames attribute → service monitors ALL foreground applications.
    typeWindowStateChanged  : catches new Activity/Dialog appearing (ads on launch).
    typeWindowContentChanged: catches dynamic ad overlays rendered after initial load.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/accessibility_service_description"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackAllMask"
    android:notificationTimeout="100"
    android:accessibilityFlags="flagDefault|flagRetrieveInteractiveWindows|flagIncludeNotImportantViews"
    android:canRetrieveWindowContent="true" />
